# =========================================================
# terraform.tfvars.example
# Copia este archivo a terraform.tfvars y edita los valores.
# terraform.tfvars NO se sube al repo (ya esta en .gitignore).
# =========================================================

aws_region    = "us-east-1"
project_name  = "innovatech"
environment   = "dev"
instance_type = "t3.micro"

# Pre-creado por AWS Academy Learner Lab
instance_profile_name = "LabInstanceProfile"

# Opcional: solo si quieres SSH ademas de SSM
# key_pair_name = "vockey"

db_name     = "innovatech"
db_password = "ChangeMe_Strong_Password_2025!"
