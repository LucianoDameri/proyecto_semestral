# =========================================================
# .dockerignore - Frontend
# Reduce el build context y evita meter cache de dev al contenedor
# =========================================================

# Node modules y artifacts
node_modules/
dist/
build/
.cache/
.parcel-cache/
.vite/

# Logs y archivos temporales
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
*.swp
*~
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/
*.iml

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Variables locales
.env
.env.*
!.env.example

# Tests / coverage
coverage/
.nyc_output/

# Datos de json-server obsoletos (no se incluyen en build de produccion)
db.json
